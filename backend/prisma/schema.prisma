generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EventType {
  page_view
  add_to_cart
  remove_from_cart
  checkout_started
  purchase
}

model Store {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  events    StoreEvent[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  googleId  String   @unique
  name      String?
  picture   String?
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
}

model StoreEvent {
  id         String    @id @default(cuid())
  eventId    String    @unique
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  eventType  EventType
  timestamp  DateTime
  data       Json
  productId  String?
  amount     Decimal?  @db.Decimal(14, 2)
  currency   String?

  @@index([storeId, timestamp(sort: Desc)])
  @@index([storeId, eventType, timestamp])
  @@index([storeId, eventType, productId])
}

